#
#		Makefile のチップ依存部(STM32MP2用)
#

#
#  チップ依存部ディレクトリ名の定義
#
CHIPDIR = $(SRCDIR)/arch/$(CORE)_$(TOOL)/$(CHIP)

#
#  コンパイルオプション
#
COPTS := $(COPTS) -mcpu=cortex-a35
LDFLAGS := $(LDFLAGS) -mcpu=cortex-a35
CDEFS := $(CDEFS) -DTOPPERS_CORTEX_A35
#  セキュア(Group0)割込みを FIQ ではなく IRQ で配送する（gicc_init, GICv2）．
#  カーネルの CPU ロックが IRQ マスクモデルのため．他 GICv2+TZ_S ターゲットには影響しない．
CDEFS := $(CDEFS) -DGIC_NO_FIQ_IN_SECURE

INCLUDES := $(INCLUDES) -I$(CHIPDIR)
LDFLAGS := $(LDFLAGS) -N

#
#  カーネルに関する定義
#
KERNEL_DIRS := $(KERNEL_DIRS) $(CHIPDIR)
KERNEL_COBJS := $(KERNEL_COBJS) chip_kernel_impl.o
KERNEL_ASMOBJS := $(KERNEL_ASMOBJS)

#
#  システムサービスに関する定義
#
SYSSVC_DIRS := $(SYSSVC_DIRS) $(CHIPDIR)

#
#  スタートアップモジュールに関する定義
#
#  START_OBJSをstart.oに設定し，LDFLAGSに-nostdlibを追加する．
#
START_OBJS := start.o $(START_OBJS)
START_OBJS := $(addprefix $(OBJDIR)/, $(START_OBJS))

$(START_OBJS): $(OBJDIR)/%.o: %.S
	$(CC) -c -o $@ -MD -MP -MF $(DEPDIR)/$*.d $(CFLAGS) $(KERNEL_CFLAGS) $<

LDFLAGS := -nostdlib $(LDFLAGS)

#
#  コア依存部
#
include $(SRCDIR)/arch/$(CORE)_$(TOOL)/common/Makefile.core
