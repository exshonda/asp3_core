{
  "version": 4,
  "include": [
    "../../cmake/presets-base.json"
  ],
  "configurePresets": [
    {
      "name": "polarfire_soc_kit",
      "inherits": "_base",
      "displayName": "PolarFire SoC Icicle Kit (U54/RV64GC, real board)",
      "description": "実機Icicle Kit用（実行手段は今後整備）",
      "toolchainFile": "${sourceDir}/cmake/toolchain-riscv64.cmake",
      "cacheVariables": {
        "ASP3_TARGET": "polarfire_soc_kit_gcc",
        "POLARFIRE_QEMU": "OFF"
      }
    },
    {
      "name": "polarfire_soc_kit-qemu",
      "inherits": "polarfire_soc_kit",
      "displayName": "PolarFire SoC Icicle Kit / QEMU (microchip-icicle-kit)",
      "description": "QEMU実行用（qemu-system-riscv64がPATHにない場合は -DQEMU_SYSTEM_RISCV64=... を付与）",
      "cacheVariables": {
        "POLARFIRE_QEMU": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "polarfire_soc_kit",
      "configurePreset": "polarfire_soc_kit"
    },
    {
      "name": "polarfire_soc_kit-qemu",
      "configurePreset": "polarfire_soc_kit-qemu"
    },
    {
      "name": "run-polarfire_soc_kit-qemu",
      "configurePreset": "polarfire_soc_kit-qemu",
      "targets": [
        "run"
      ]
    }
  ]
}
