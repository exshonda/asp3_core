# -*- coding: utf-8 -*-
#
#		パス2の生成スクリプトのターゲット依存部（Linux用）
# 
#   $Id: target_kernel.trb 1662 2022-09-27 15:19:42Z ertl-hiro $
# 

#
#  使用できるCPU例外ハンドラ番号
#
#  CPU例外ハンドラ番号は，シグナル番号に一致させる．CPU例外として使用
#  できるシグナルをリストアップする（シグナル番号を取り出すために，
#  target_sym.defにもリストアップする必要がある）．
#
$EXCNO_VALID = [ $EXCNO_SIGFPE, $EXCNO_SIGBUS, $EXCNO_SIGSEGV ]

#
#  生成スクリプトのPOSIX依存部
#
IncludeTrb("posix_kernel.trb")
