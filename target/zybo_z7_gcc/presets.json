{
  "version": 4,
  "include": [
    "../../cmake/presets-base.json"
  ],
  "configurePresets": [
    {
      "name": "zybo_z7",
      "inherits": "_base",
      "displayName": "Zybo Z7 (Cortex-A9, real board)",
      "description": "実機Zybo Z7用（実行はxilinx_sdk/jtag.tcl）",
      "toolchainFile": "${sourceDir}/cmake/toolchain-arm-none-eabi.cmake",
      "cacheVariables": {
        "ASP3_TARGET": "zybo_z7_gcc",
        "ZYBO_QEMU": "OFF"
      }
    },
    {
      "name": "zybo_z7-qemu",
      "inherits": "zybo_z7",
      "displayName": "Zybo Z7 / QEMU (xilinx-zynq-a9)",
      "description": "QEMU実行用（TOPPERS_USE_QEMU定義＝ext_kerでQEMU終了）",
      "cacheVariables": {
        "ZYBO_QEMU": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "zybo_z7",
      "configurePreset": "zybo_z7"
    },
    {
      "name": "zybo_z7-qemu",
      "configurePreset": "zybo_z7-qemu"
    },
    {
      "name": "run-zybo_z7-qemu",
      "configurePreset": "zybo_z7-qemu",
      "targets": [
        "run"
      ]
    }
  ]
}
