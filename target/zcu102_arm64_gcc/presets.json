{
  "version": 4,
  "include": [
    "../../cmake/presets-base.json"
  ],
  "configurePresets": [
    {
      "name": "zcu102_arm64",
      "inherits": "_base",
      "displayName": "ZCU102 (Cortex-A53, real board)",
      "description": "実機ZCU102用（STG初期化あり・実行手段は今後整備）",
      "toolchainFile": "${sourceDir}/cmake/toolchain-a35.cmake",
      "cacheVariables": {
        "ASP3_TARGET": "zcu102_arm64_gcc",
        "ZCU102_QEMU": "OFF"
      }
    },
    {
      "name": "zcu102_arm64-qemu",
      "inherits": "zcu102_arm64",
      "displayName": "ZCU102 / QEMU (xlnx-zcu102)",
      "description": "QEMU実行用（aarch64-none-elf無しの環境は -DA35_TOOLCHAIN_PREFIX=aarch64-linux-gnu- を付与）",
      "cacheVariables": {
        "ZCU102_QEMU": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "zcu102_arm64",
      "configurePreset": "zcu102_arm64"
    },
    {
      "name": "zcu102_arm64-qemu",
      "configurePreset": "zcu102_arm64-qemu"
    },
    {
      "name": "run-zcu102_arm64-qemu",
      "configurePreset": "zcu102_arm64-qemu",
      "targets": [
        "run"
      ]
    }
  ]
}
