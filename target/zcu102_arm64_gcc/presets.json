{
  "version": 4,
  "include": [
    "../../cmake/presets-base.json"
  ],
  "configurePresets": [
    {
      "name": "a64-qemu",
      "inherits": "_base",
      "displayName": "Cortex-A53 / QEMU (xlnx-zcu102)",
      "description": "非Pico：ASP3_TARGET直接指定。ハードなし・ARMv8-A確認用（aarch64-none-elf無しの環境は -DA35_TOOLCHAIN_PREFIX=aarch64-linux-gnu- を付与）",
      "toolchainFile": "${sourceDir}/cmake/toolchain-a35.cmake",
      "cacheVariables": {
        "ASP3_TARGET": "zcu102_arm64_gcc"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "a64-qemu",
      "configurePreset": "a64-qemu"
    },
    {
      "name": "run-a64-qemu",
      "configurePreset": "a64-qemu",
      "targets": [
        "run"
      ]
    }
  ]
}
