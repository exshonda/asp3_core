{
  "version": 4,
  "include": [
    "../../cmake/presets-base.json"
  ],
  "configurePresets": [
    {
      "name": "mps2_an386-qemu",
      "inherits": "_base",
      "displayName": "Cortex-M4+FPU / QEMU (mps2-an386)",
      "description": "QEMU専用ターゲット。ハードなし・ARMv7-M(レガシーCMSDK/非TZ/FPv4-SP)確認用",
      "toolchainFile": "${sourceDir}/cmake/toolchain-arm-none-eabi.cmake",
      "cacheVariables": {
        "ASP3_TARGET": "mps2_an386_gcc"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "mps2_an386-qemu",
      "configurePreset": "mps2_an386-qemu"
    },
    {
      "name": "run-mps2_an386-qemu",
      "configurePreset": "mps2_an386-qemu",
      "targets": [
        "run"
      ]
    }
  ]
}
